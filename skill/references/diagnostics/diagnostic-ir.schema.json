{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill/references/diagnostics/diagnostic-ir.schema.json",
  "title": "Diagnostic IR",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "case_family",
    "claim_type",
    "deformation",
    "concealment_mode",
    "do_orient",
    "reason_category",
    "routing_gate",
    "matched_modules",
    "restoration_target",
    "next_move"
  ],
  "properties": {
    "case_family": {
      "type": "string",
      "minLength": 1
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "logical",
        "metaphysical",
        "moral",
        "historical",
        "transmission",
        "phenomenological",
        "authority"
      ]
    },
    "deformation": {
      "type": "string",
      "enum": [
        "Iʿtiqādāt mawrūtha",
        "Mushābara fāsida",
        "Hawā",
        "Ẓann",
        "Taqlīd",
        "ʿĀda",
        "Gharaḍ",
        "Shubha"
      ]
    },
    "concealment_mode": {
      "type": "string",
      "enum": [
        "irad",
        "juhud",
        "inkar",
        "istikbar",
        "nifaq",
        "mode-?",
        "compound"
      ]
    },
    "do_orient": {
      "type": "string",
      "enum": [
        "truth-seek",
        "identity-perf",
        "autotelic",
        "zann-mode",
        "mixed"
      ]
    },
    "reason_category": {
      "oneOf": [
        { "type": "integer", "enum": [1, 2, 3, 4] },
        { "type": "string", "enum": ["1", "2", "3", "4"] }
      ]
    },
    "routing_gate": {
      "type": "string",
      "enum": [
        "open",
        "V2-required",
        "deformation-first",
        "register-hold",
        "stop-condition"
      ]
    },
    "matched_modules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "module_class": { "type": "string", "enum": ["case-library", "tactic", "procedure", "technique"] },
          "content_bearing": { "type": "boolean" },
          "doctrinal_case_file": { "type": "boolean" }
        },
        "required": ["id", "module_class", "content_bearing", "doctrinal_case_file"]
      },
      "minItems": 1
    },
    "restoration_target": {
      "type": "string",
      "minLength": 1
    },
    "next_move": {
      "type": "string",
      "minLength": 1
    },

    "ns_code": {
      "type": "string",
      "enum": ["NS-1", "NS-2", "NS-3", "NS-4", "NS-5", "NS-6", "NS-7", "NS-8", "NS-9", "NS-10", "NS-11", "NS-12", "provisional"]
    },
    "rt_marker": {
      "type": "string",
      "enum": ["RT-1", "RT-2", "RT-3", "RT-4", "none"]
    },
    "read_status": {
      "type": "string",
      "enum": ["dominant", "distributed", "underdetermined"]
    },
    "confidence": {
      "type": "string",
      "enum": ["strong", "provisional", "low"]
    },
    "p7_stops_active": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Stop-1", "Stop-2", "Stop-3", "Stop-4", "Stop-5", "none"]
      },
      "uniqueItems": true
    },
    "prohibited_moves": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["PM-1", "PM-2", "PM-3", "PM-4"]
      },
      "uniqueItems": true
    },
    "backbone_predicates_active": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["C-1", "C-2", "C-3", "T-1", "T-2", "T-3", "O-1", "O-2", "O-3", "K-1", "K-2"]
      },
      "uniqueItems": true
    },
    "foreign_premise": { "type": "string", "minLength": 1 },
    "philosophical_usurpation": { "type": "string", "minLength": 1 },
    "architectural_layer_disrupted": {
      "type": "string",
      "enum": [
        "fiṭrah",
        "sound-reason",
        "authentic-transmission",
        "inferential-route",
        "transcendence-immanence",
        "prophetic-authority",
        "none"
      ]
    },
    "ontological_disorder": {
      "type": "string",
      "enum": [
        "category-mistake",
        "illicit-analogy",
        "equivocal-predication",
        "composition-panic",
        "person-multiplicity-conflation",
        "perfect-being-usurpation",
        "none"
      ]
    },
    "source_basis": {
      "type": "string"
    },
    "inference_boundary_active": {
      "type": "string",
      "enum": ["yes", "no"]
    },
    "output_shape": {
      "type": "string",
      "enum": [
        "content",
        "relational",
        "maieutic",
        "invitational",
        "single-response",
        "held-pending"
      ]
    },
    "what_is_withheld_and_why": { "type": "string" },
    "what_remains_live": { "type": "string" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "read_status": { "const": "underdetermined" },
          "confidence": { "const": "strong" }
        },
        "required": ["read_status", "confidence"]
      },
      "then": false
    },
    {
      "if": {
        "properties": {
          "reason_category": { "enum": [3, 4, "3", "4"] }
        },
        "required": ["reason_category"]
      },
      "then": {
        "properties": {
          "routing_gate": {
            "not": { "const": "open" }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "concealment_mode": { "const": "juhud" }
        },
        "required": ["concealment_mode"]
      },
      "then": {
        "properties": {
          "output_shape": {
            "not": { "const": "content" }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "p7_stops_active": { "contains": { "const": "Stop-1" } }
        },
        "required": ["p7_stops_active"]
      },
      "then": {
        "properties": {
          "output_shape": {
            "not": { "const": "content" }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "routing_gate": { "const": "V2-required" }
        },
        "required": ["routing_gate"]
      },
      "then": {
        "properties": {
          "matched_modules": {
            "items": {
              "content_bearing": false
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "do_orient": { "const": "identity-perf" }
        },
        "required": ["do_orient"]
      },
      "then": {
        "properties": {
          "matched_modules": {
            "items": {
              "doctrinal_case_file": false
            }
          }
        }
      }
    }
  ]
}